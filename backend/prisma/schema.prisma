generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id         Int      @id @default(autoincrement())
  title      String
  transcript String   @db.LongText
  summary    String   @db.LongText
  createdAt  DateTime @default(now())
}